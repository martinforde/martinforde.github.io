Cell[BoxData[{
 RowBox[{"\"\<Assume F0=1\>\"", ";"}], "\[IndentingNewLine]", 
 RowBox[{"\"\<SVI Call price function\>\"", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SVICall", "[", "K_", "]"}], "=", 
   RowBox[{"BSCall", "[", " ", 
    RowBox[{
     RowBox[{"Log", "[", "K", "]"}], ",", 
     RowBox[{"V", "[", 
      RowBox[{"Log", "[", "K", "]"}], "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"\"\<SVI Density using Breeden-Litzenberger\>\"", 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"q", "[", "K_", "]"}], "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"SVICall", "[", "K", "]"}], ",", "K", ",", "K"}], "]"}], 
