Cell[BoxData[{
 RowBox[{"\"\<SVI formula\>\"", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"V", "[", "x_", "]"}], "=", 
   RowBox[{"a", "+", 
    RowBox[{"b", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[Rho]", 
        RowBox[{"(", 
         RowBox[{"x", "-", "m"}], ")"}]}], "+", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", "-", "m"}], ")"}], "^", "2"}], "+", 
         RowBox[{"\[Sigma]", "^", "2"}]}], "]"}]}], ")"}]}]}]}], 
  ";"}]}], "Input",
