Cell[BoxData[
 RowBox[{"\"\<Black-Scholes Call price function in terms of log-moneyness and \
v=\[Sigma]^2 T with S0=1,r=0\>\"", ";", 
  RowBox[{
   RowBox[{"BSCall", "[", 
    RowBox[{"x_", ",", "v_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"\[CapitalPhi]", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "x"}], "+", 
        RowBox[{
         RowBox[{"1", "/", "2"}], " ", "v"}]}], ")"}], "/", 
      RowBox[{"Sqrt", "[", "v", "]"}]}], "]"}], "-", 
    RowBox[{
     RowBox[{"Exp", "[", "x", "]"}], 
     RowBox[{"\[CapitalPhi]", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "x"}], "-", 
         RowBox[{
          RowBox[{"1", "/", "2"}], " ", "v"}]}], ")"}], "/", 
       RowBox[{"Sqrt", "[", "v", "]"}]}], "]"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.91576947732145*^9, 3.9157695277412863`*^9}, {
