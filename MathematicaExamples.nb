Cell[BoxData[{
 RowBox[{"\"\<For symmetric \[Alpha]-stable process: E(exp(i U \
X_t))=exp(-|u|^\[Alpha])\>\"", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Phi]", "[", "u_", "]"}], "=", 
   RowBox[{"Exp", "[", 
    RowBox[{"-", 
     RowBox[{
      RowBox[{"Abs", "[", "u", "]"}], "^", "\[Alpha]"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.98204125069608*^9, 3.982041303568102*^9}, {
  3.982042898304878*^9, 
  3.982042913350809*^9}},ExpressionUUID->"7f5265f6-0c5f-4a8e-a228-\
e8a3d31d2358"],

Cell[BoxData[
 RowBox[{"\"\<Inverse Fourier Transform, assume \[Alpha] in (1,2)\>\"", 
  ";"}]], "Input",
 CellChangeTimes->{{3.9820413102177553`*^9, 3.9820413154559793`*^9}, {
  3.982041352574369*^9, 3.9820413588866787`*^9}, {3.982042918750215*^9, 
  3.98204291967076*^9}},ExpressionUUID->"ccf1497a-d864-44a2-a673-\
7cc0d4125069"],

Cell[BoxData[
 RowBox[{"\"\<Plot density of Xt using the Inverse Fourier Transform \
formula\>\"", ";"}]], "Input",
 CellChangeTimes->{{3.982041367840019*^9, 3.982041372493775*^9}, {
  3.98204292515055*^9, 
  3.982042934582076*^9}},ExpressionUUID->"9a543a48-7823-4dba-8d89-\
33bfd4f0a22e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Alpha]", "=", 
   RowBox[{"3", "/", "2"}]}], ";", 
  RowBox[{"t", "=", "1"}], ";", 
  RowBox[{"x", "=", "0"}], ";", 
  RowBox[{"Clear", "[", "x", "]"}], ";", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"2", "\[Pi]"}], ")"}]}], 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "I"}], " ", "u", " ", "x"}], "]"}], 
        RowBox[{"\[Phi]", "[", "u", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"u", ",", 
         RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}]}], "]"}]}], ",", 
    
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
    RowBox[{"PlotPoints", "\[Rule]", "20"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.982041317440679*^9, 3.982041422860791*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"b39bb1b4-3180-4ab7-bb4f-55919518e55a"],

