Cell[BoxData[
 RowBox[{"\"\<Standard Normal cdf\>\"", ";", 
  RowBox[{
   RowBox[{"\[CapitalPhi]", "[", "x_", "]"}], "=", 
   RowBox[{
    RowBox[{"1", "/", "2"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Erf", "[", 
       RowBox[{"x", "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}], "+", "1"}], ")"}]}]}], ";", 
  
  RowBox[{
   RowBox[{"\[CapitalPhi]c", "[", "x_", "]"}], "=", 
   RowBox[{"1", "-", 
    RowBox[{"\[CapitalPhi]", "[", "x", "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9820409097826653`*^9, 3.98204093711206*^9}, {
  3.982041013093842*^9, 3.982041044834598*^9}, {3.98204294653402*^9, 
  3.982042952605486*^9}},ExpressionUUID->"10325b51-1607-4a2b-b1d2-\
e06434a467e8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"\[CapitalPhi]", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
    RowBox[{"GridLines", "\[Rule]", "Automatic"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.982040925104168*^9, 3.982040978654471*^9}},
 CellLabel->"In[34]:=",ExpressionUUID->"a7ae8c98-e570-4517-aad0-c40f12af8e43"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\"\<Compute P(M_t>b)=P(\[Tau]b<=t)=2 P(W_t>b)\>\"", ";", 
  RowBox[{
   RowBox[{"F", "[", "t_", "]"}], "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"2", 
     RowBox[{"\[CapitalPhi]c", "[", 
      RowBox[{"b", "/", 
       RowBox[{"Sqrt", "[", "t", "]"}]}], "]"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.982041047306759*^9, 3.9820411431760406`*^9}, {
  3.9820429660053787`*^9, 
  3.9820429672211037`*^9}},ExpressionUUID->"d50cb48d-2770-43d4-b1aa-\
23a26e8f47db"],

Cell[BoxData[
 RowBox[{"1", "-", 
  RowBox[{"Erf", "[", 
   FractionBox["b", 
    RowBox[{
     SqrtBox["2"], " ", 
     SqrtBox["t"]}]], "]"}]}]], "Output",
 CellChangeTimes->{{3.9820410752483063`*^9, 3.9820410849485407`*^9}, {
  3.98204113420339*^9, 3.982041143782181*^9}},
 CellLabel->"Out[44]=",ExpressionUUID->"faffe71a-2aea-416b-bc9e-4feecc957fe7"]
}, Open  ]],

Cell[BoxData[
 RowBox[{"\"\<F'[t] is density of \[Tau]b\>\"", ";"}]], "Input",
 CellChangeTimes->{{3.9820429772925463`*^9, 3.982042983939293*^9}},
 CellLabel->"In[64]:=",ExpressionUUID->"d1fc5786-0184-41a3-a406-edd596ae872e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "t_", "]"}], "=", 
  RowBox[{
   RowBox[{"F", "'"}], "[", "t", "]"}]}]], "Input",
 CellChangeTimes->{{3.9820411655743513`*^9, 3.982041170286559*^9}},
 CellLabel->"In[47]:=",ExpressionUUID->"855d254c-4fa8-4faa-8f4c-e31e96f010ce"],

Cell[BoxData[
 FractionBox[
  RowBox[{"b", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["b", "2"], 
      RowBox[{"2", " ", "t"}]]}]]}], 
  RowBox[{
   SqrtBox[
    RowBox[{"2", " ", "\[Pi]"}]], " ", 
   SuperscriptBox["t", 
    RowBox[{"3", "/", "2"}]]}]]], "Output",
 CellChangeTimes->{3.982041171177514*^9},
 CellLabel->"Out[47]=",ExpressionUUID->"170b299c-4618-453a-ac4a-06547ad73924"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"b", "=", "1"}], ";", 
  RowBox[{"Clear", "[", "b", "]"}], ";", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"f", "[", "t", "]"}], ",", 
